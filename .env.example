# Azure credentials (required)
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# Set to true to use Managed Identity instead of client secret
AZURE_USE_MSI=false

# Azure AI Foundry (optional – enables AI-powered recommendations)
AI_FOUNDRY_ENDPOINT=https://your-project.openai.azure.com/
AI_FOUNDRY_KEY=your-api-key
AI_FOUNDRY_DEPLOYMENT=gpt-4o

# Azure Storage (optional – persists graph snapshots)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...

# Azure Key Vault (optional – retrieve secrets at runtime instead of env vars)
KEY_VAULT_URI=https://your-keyvault.vault.azure.net/

# Dashboard
DASHBOARD_PORT=5000
DASHBOARD_DEBUG=false
